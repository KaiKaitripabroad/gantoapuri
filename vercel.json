{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.5",
            "includeFiles": [
                "app/**",
                "bootstrap/**",
                "config/**",
                "database/**",
                "public/**",
                "resources/**",
                "routes/**",
                "storage/**",
                "artisan",
                "composer.json",
                "composer.lock"
            ]
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
